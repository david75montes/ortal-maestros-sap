# Variables de entorno (opcional para desarrollo local)

# Firebase (si integras en el futuro)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# API Backend (si cambias a Supabase, Railway, etc.)
# VITE_API_URL=http://localhost:3000
# VITE_API_KEY=

# Notas:
# - Copia este archivo a .env.local para usar variables locales
# - Las variables deben empezar con VITE_ para estar disponibles en el navegador
# - Nunca commits .env.local a Git (usa .gitignore)
